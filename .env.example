# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── LLM provider ──────────────────────────────────────────────────────────────
# Set to "vllm" or "openai"
LLM_PROVIDER=vllm

# ── Option A: vLLM (local native) ─────────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=qwen3.5-9b-awq
# vLLM serve command:
#   vllm serve QuantTrio/Qwen3.5-9B-AWQ \
#     --served-model-name qwen3.5-9b-awq \
#     --quantization awq_marlin \
#     --enable-auto-tool-choice \
#     --tool-call-parser qwen3_coder \
#     --reasoning-parser qwen3 \
#     --gpu-memory-utilization 0.90 \
#     --max-num-seqs 1 \
#     --port 8000

# ── Option B: vLLM via Docker (docker-compose.yml GPU stack) ──────────────────
# VLLM_BASE_URL=http://vllm:8000/v1   # service name resolves inside Docker network
# HF_TOKEN=hf_...                     # required to download the model
# VLLM_HF_MODEL=QuantTrio/Qwen3.5-9B-AWQ   # HuggingFace model repo
# VLLM_MODEL=qwen3.5-9b-awq                # served model name (used by the app)
# VLLM_QUANTIZATION=awq_marlin
# VLLM_TOOL_CALL_PARSER=qwen3_coder
# VLLM_REASONING_PARSER=qwen3

# ── Option C: OpenAI API ──────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
